@page
@model IndexModel
@{
    ViewData["Title"] = "Photography Packages";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Photography Packages</h2>

    @* SEARCH BAR *@
    <form asp-page="./Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="SearchString" value="@Model.CurrentFilter" 
                   class="form-control" placeholder="Search by package title...">
            <button class="btn btn-dark" type="submit">Search</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @* DATA TABLE *@
    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>
                    <a asp-page="./Index" asp-route-sortOrder="@Model.NameSort" class="text-white text-decoration-none">
                        Package Name @(Model.CurrentSort == "" ? "▲" : "▼")
                    </a>
                </th>
                <th>
                    <a asp-page="./Index" asp-route-sortOrder="@Model.PriceSort" class="text-white text-decoration-none">
                        Price @(Model.CurrentSort == "Price" ? "▲" : "▼")
                    </a>
                </th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.Category?.Name</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="./Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-page="./Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* PAGING CONTROLS *@
    @{
        var prevDisabled = !Model.Products.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.Products.HasNextPage ? "disabled" : "";
    }

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @prevDisabled">
                <a asp-page="./Index" 
                   asp-route-sortOrder="@Model.CurrentSort" 
                   asp-route-pageIndex="@(Model.Products.PageIndex - 1)" 
                   asp-route-searchString="@Model.CurrentFilter" 
                   class="page-item btn btn-outline-dark me-2">Previous</a>
            </li>
            <li class="page-item @nextDisabled">
                <a asp-page="./Index" 
                   asp-route-sortOrder="@Model.CurrentSort" 
                   asp-route-pageIndex="@(Model.Products.PageIndex + 1)" 
                   asp-route-searchString="@Model.CurrentFilter" 
                   class="page-item btn btn-outline-dark">Next</a>
            </li>
        </ul>
    </nav>
</div>