@page "{id:int}"
@model EditModel

<div class="container mt-5" style="max-width: 600px;">
    <div class="card p-4 shadow-sm rounded-4">
        <h2 class="text-center" style="color: #ff758c;">Edit Package</h2>
        <form method="post">
            <input type="hidden" asp-for="Product.ProductID" />
            <div class="mb-3">
                <label asp-for="Product.Title" class="form-label"></label>
                <input asp-for="Product.Title" class="form-control rounded-pill" />
            </div>
            <div class="mb-3">
                <label asp-for="Product.Price" class="form-label"></label>
                <input asp-for="Product.Price" class="form-control rounded-pill" />
            </div>
            <div class="mb-3">
                <label asp-for="Product.Description" class="form-label"></label>
                <textarea asp-for="Product.Description" class="form-control rounded-4" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100 rounded-pill" style="background-color: #ffb6c1; border: none;">Save Changes</button>
        </form>
    </div>
</div>