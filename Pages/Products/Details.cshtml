@page "{id:int}"
@model LensAndLight.Pages.Products.DetailsModel

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-6">
                @* Using a placeholder if the ImageUrl is missing *@
                <img src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? "/images/placeholder.jpg" : Model.Product.ImageUrl)" 
                     class="img-fluid h-100" 
                     style="min-height: 400px; object-fit: cover;" 
                     alt="@Model.Product.Title">
            </div>
            <div class="col-md-6 p-5 d-flex flex-column justify-content-center">
                <h1 style="color: #ff758c; font-weight: bold;">@Model.Product.Title</h1>
                <span class="badge bg-light text-muted mb-3 p-2 shadow-sm" style="width: fit-content;">
                    Category: @Model.Product.Category?.Name
                </span>
                <hr />
                <p class="lead text-muted">@Model.Product.Description</p>
                <h2 class="fw-bold mb-4" style="color: #ff8fa3;">@Model.Product.Price.ToString("C")</h2>
                
                <div class="d-flex gap-3 mt-3">
                    <a asp-page="./Edit" asp-route-id="@Model.Product.ProductID" class="btn btn-warning rounded-pill px-4 shadow-sm">Edit Package</a>
                    <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">Back to Gallery</a>
                </div>
            </div>
        </div>
    </div>
</div>