@page "{id:int}"
@model DeleteModel

<div class="container mt-5 text-center">
    <div class="card p-5 shadow-sm border-danger rounded-4">
        <h2 class="text-danger">Are you sure?</h2>
        <p>You are about to delete <strong>@Model.Product.Title</strong>. This cannot be undone!</p>
        <form method="post">
            <input type="hidden" asp-for="Product.ProductID" />
            <button type="submit" class="btn btn-danger rounded-pill px-5">Yes, Delete it</button>
            <a asp-page="./Index" class="btn btn-light rounded-pill px-5">Cancel</a>
        </form>
    </div>
</div>