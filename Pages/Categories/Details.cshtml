@page "{id:int}"
@model LensAndLight.Pages.Categories.DetailsModel

@{
    ViewData["Title"] = "Category Details";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 bg-light p-4 mb-5" style="border-radius: 20px;">
        <h1 class="display-5" style="color: #ff8fa3;">@Model.Category.Name</h1>
        <p class="lead">@Model.Category.Description</p>
        <div>
            <a asp-page="./Edit" asp-route-id="@Model.Category.CategoryID" class="btn btn-warning rounded-pill px-4">Edit Category</a>
            <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
        </div>
    </div>

    <div class="mt-4">
        <h3 class="mb-4" style="color: #ff758c;">Packages Available in @Model.Category.Name</h3>
        
        @if (Model.Category.Products != null && Model.Category.Products.Any())
        {
            <div class="row">
                @foreach (var product in Model.Category.Products)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" class="card-img-top" alt="@product.Title" style="height: 200px; object-fit: cover;">
                            }
                            <div class="card-body d-flex flex-column text-center">
                                <h5 class="card-title fw-bold" style="color: #ff758c;">@product.Title</h5>
                                <p class="card-text text-muted flex-grow-1 small">@product.Description</p>
                                <div class="mt-auto">
                                    <h6 class="text-dark fw-bold">@product.Price.ToString("C")</h6>
                                    <hr />
                                    @* *@
                                    <a asp-page="/Products/Details" asp-route-id="@product.ProductID" class="btn btn-sm btn-outline-pink w-100 rounded-pill" style="border-color: #ffb6c1; color: #ff758c;">
                                        View Package Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info rounded-pill text-center">
                No photography packages have been added to this category yet.
            </div>
        }
    </div>
</div>